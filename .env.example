# ============================================================
# Plano Mestre PDF API — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# NÃO commite o arquivo .env no repositório.
# ============================================================

# --- Supabase ---
# URL do projeto (Dashboard → Settings → API → URL)
SUPABASE_URL=https://xxxxx.supabase.co

# Chave service_role (Dashboard → Settings → API → service_role secret)
# ⚠️ NUNCA exponha esta chave no frontend. Ela bypassa RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# --- Segurança da API ---
# Chave secreta que o frontend envia no header x-api-key
# Gere uma com: openssl rand -hex 32
API_SECRET=cole-aqui-uma-chave-segura

# --- Servidor ---
PORT=3000

# --- CORS ---
# Domínio do frontend (sem barra no final)
FRONTEND_URL=https://seu-projeto.netlify.app
